# AIHubMix API 配置（兼容 OpenAI 接口）
# 在 https://aihubmix.com 申请 API Key
AIHUBMIX_API_KEY=your-api-key-here
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# 模型配置
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional: use a separate OpenAI-compatible provider for embeddings, e.g. ModelScope.
# MODELSCOPE_API_KEY=your-modelscope-access-token
# EMBEDDING_BASE_URL=https://api-inference.modelscope.cn/v1
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# RAG 配置
TOP_K=3
TEMPERATURE=0.1
MAX_TOKENS=2048
