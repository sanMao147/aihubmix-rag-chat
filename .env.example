# AIHubMix API 配置（兼容 OpenAI 接口）
# 在 https://aihubmix.com 申请 API Key
AIHUBMIX_API_KEY=your-api-key-here
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# 模型配置
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# RAG 配置
TOP_K=3
TEMPERATURE=0.1
MAX_TOKENS=2048

# Neo4j 图数据库配置（可选，不配置时自动降级为传统检索）
# 注册 https://neo4j.com/cloud/aura/ 获取免费实例
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password
# NEO4J_DATABASE=neo4j

# 父文档检索配置
# ENABLE_PARENT_DOC_RETRIEVAL=true
# PARENT_DOC_TOP_N=3
# PARENT_DOC_MAX_CHARS=4000

# 图 RAG 配置
# MAX_GRAPH_DEPTH=3
